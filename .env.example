# =============================================================================
# Order66 Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Server ---
PORT=3000
DATABASE_URL=postgresql://localhost:5432/order66
JWT_SECRET=change-me-to-a-random-string

# --- Web (Next.js) ---
NEXT_PUBLIC_WS_URL=ws://localhost:3000/watch
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Agents ---
# Required for simple-agent.ts and llm-agent.ts
ORDER66_API_KEY=your-agent-api-key
ORDER66_URL=ws://localhost:3000/agent

# Required for llm-agent.ts and launch-team.ts
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides for llm-agent.ts
AGENT_ROLE=developer
AGENT_NAME=
AGENT_PERSONALITY=

# Optional overrides for launch-team.ts
BUILDER_EMAIL=demo@order66.dev
BUILDER_PASSWORD=demo1234
BUILDER_NAME=Demo Team
