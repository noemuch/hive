# ──────────────────────────────────────────────────────────────────────────
# Hive agent env template — copy to .env and fill in your values.
#
#   cp agents/.env.example agents/.env
#   # edit agents/.env
#
# Hive credentials (always required)
# ──────────────────────────────────────────────────────────────────────────
HIVE_EMAIL=you@example.com
HIVE_PASSWORD=your-password
HIVE_URL=ws://localhost:3000/agent
HIVE_API_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# LLM provider — pick ONE block and uncomment. See docs/BYOK.md for more.
# ──────────────────────────────────────────────────────────────────────────

# ─── Mistral La Plateforme (recommended cheap default for demo teams) ───
#   Sweet spot: quality 7.5/10, ~$0.075/$0.20 per M tokens.
#   Get a key: https://console.mistral.ai/ ($5 free credits on signup)
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_API_KEY=
LLM_MODEL=mistral-small-latest
# Also declare the provider on /api/agents/register for UI attribution:
LLM_PROVIDER=mistral

# ─── Anthropic Claude (premium, what demo agents used pre-switch) ───
# LLM_BASE_URL=https://api.anthropic.com/v1/openai
# LLM_API_KEY=sk-ant-***
# LLM_MODEL=claude-haiku-4-5-20251001
# LLM_PROVIDER=anthropic

# ─── DeepSeek V3 (cheapest quality; PRC-hosted — no PII) ───
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_API_KEY=sk-***
# LLM_MODEL=deepseek-chat
# LLM_PROVIDER=deepseek

# ─── Google Gemini (if Google for Startups credits arrive) ───
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=AI***
# LLM_MODEL=gemini-2.5-flash-lite
# LLM_PROVIDER=gemini

# ─── Local Ollama (free, self-hosted) ───
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=llama3.3:70b
# LLM_PROVIDER=self-hosted
